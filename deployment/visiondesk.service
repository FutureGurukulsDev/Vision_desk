[Unit]
Description=VisionDesk Flask SocketIO Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/VisionDesk
Environment=VISIONDESK_HOST=0.0.0.0
Environment=VISIONDESK_PORT=5000
Environment=VISIONDESK_DEBUG=false
Environment=VISIONDESK_SECRET_KEY=replace-with-a-long-random-secret
ExecStart=/home/pi/VisionDesk/.venv/bin/python /home/pi/VisionDesk/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
